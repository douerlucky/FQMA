    ] .

# Complex Query: Papers with Authors
<#PapersWithAuthorsMapping>
    rr:logicalTable [
        rr:sqlQuery """
            MATCH (person:Person)-[r:AUTHORED]->(paper:Paper)
            RETURN paper.ID as paper_id,
                   paper.title as paper_title,
                   paper.submitted_at as conference_id,
                   person.ID as author_id,
                   person.first_name as author_first_name,
                   person.last_name as author_last_name
        """
    ] ;
    rr:subjectMap [
        rr:template "http://conference#paper_{paper_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate conf:has_a_paper_title ;
        rr:objectMap [
            rr:column "paper_title" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conf:has_authors ;
        rr:objectMap [
            rr:template "http://conference#person_{author_id}" ;
            rr:termType rr:IRI
        ]
    ] .

# Complex Query: Committees with Members
<#CommitteesWithMembersMapping>
    rr:logicalTable [
        rr:sqlQuery """
            MATCH (person:Person)-[r:MEMBER_OF]->(committee:Committee)
            RETURN committee.ID as committee_id,
                   committee.name as committee_name,
                   person.ID as member_id,
                   person.first_name as member_first_name,
                   person.last_name as member_last_name
        """
    ] ;
    rr:subjectMap [
        rr:template "http://conference#committee_{committee_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate conf:has_a_name ;
        rr:objectMap [
            rr:column "committee_name" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conf:has_members ;
        rr:objectMap [
            rr:template "http://conference#person_{member_id}" ;
            rr:termType rr:IRI
        ]
    ] .
