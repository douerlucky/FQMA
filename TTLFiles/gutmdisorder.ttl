# Food increases microbiota abundance relationship mapping - 改进版本
<#FoodIncreasesMicrobiotaAbundanceMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT DISTINCT hacrbf.microbiota_name, hacrbf.relationship as food_name
            FROM gutmdisorder.food_gut_microbiota_change_results fgmcr
            JOIN relationship.has_abundance_change_results_by_food hacrbf
            ON fgmcr.index = hacrbf.index
            WHERE fgmcr.Alteration = 'increase'
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/food/{food_name}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:increases_microbiota_abundance_by_food ;
        rr:objectMap [
            rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/microbiota/{microbiota_name}"
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:food_name ;
        rr:objectMap [ rr:column "food_name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_name ;
        rr:objectMap [ rr:column "microbiota_name" ; rr:datatype xsd:string ]
    ] .

