# Additional result class mappings
<#FoodMicrobiotaChangeResultClassMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT DISTINCT 'FoodMicrobiotaChangeResult' as result_type
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology#FoodMicrobiotaChangeResult" ;
        rr:class owl:Class
    ] .

<#DrugMicrobiotaChangeResultClassMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT DISTINCT 'DrugMicrobiotaChangeResult' as result_type
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology#DrugMicrobiotaChangeResult" ;
        rr:class owl:Class
    ] .