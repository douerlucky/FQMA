@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix onto: <http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology#> .

# Food Gut Microbiota Change Results Mapping
<#FoodGutMicrobiotaChangeResultsMapping>
    rr:logicalTable [ rr:tableName "food_gut_microbiota_change_results" ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/food_microbiota_result/{index}" ;
        rr:class onto:FoodMicrobiotaChangeResult
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:food_microbiota_index ;
        rr:objectMap [ rr:column "index" ; rr:datatype xsd:integer ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_name ;
        rr:objectMap [ rr:column "microbiota_name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:alteration_type ;
        rr:objectMap [ rr:column "Alteration" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:host_type ;
        rr:objectMap [ rr:column "host_type" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:description ;
        rr:objectMap [ rr:column "description" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:evidence_score ;
        rr:objectMap [ rr:column "Evidence" ; rr:datatype xsd:integer ]
    ] .

