# ====================================================================
# 实体映射 - Entity Mappings
# ====================================================================

# Disorder entity mapping
<#DisorderMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT DISTINCT relationship as disorder_name
            FROM relationship.has_abundance_change_results_by_disorder
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/disorder/{disorder_name}" ;
        rr:class onto:Disorder
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:disorder_name ;
        rr:objectMap [ rr:column "disorder_name" ; rr:datatype xsd:string ]
    ] .

# Drug entity mapping
<#DrugMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT DISTINCT relationship as drug_name
            FROM relationship.has_abundance_change_results_by_drug
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/drug/{drug_name}" ;
        rr:class onto:Drug
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:drug_name ;
        rr:objectMap [ rr:column "drug_name" ; rr:datatype xsd:string ]
    ] .

# Food entity mapping
<#FoodMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT DISTINCT relationship as food_name
            FROM relationship.has_abundance_change_results_by_food
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/food/{food_name}" ;
        rr:class onto:Food
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:food_name ;
        rr:objectMap [ rr:column "food_name" ; rr:datatype xsd:string ]
    ] .

# Metabolite entities from expression change results
<#MetaboliteFromExpressionMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT DISTINCT relationship as metabolite_name
            FROM relationship.has_expression_change_results_by_metabolite
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/metabolite/{metabolite_name}" ;
        rr:class onto:Metabolite
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:metabolite_name ;
        rr:objectMap [ rr:column "metabolite_name" ; rr:datatype xsd:string ]
    ] .

# Microbiota entities from expression change results
<#MicrobiotaFromExpressionMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT DISTINCT relationship as microbiota_name
            FROM relationship.has_expression_change_results_by_microbiota
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/microbiota/{microbiota_name}" ;
        rr:class onto:MicrobiotaName
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_name ;
        rr:objectMap [ rr:column "microbiota_name" ; rr:datatype xsd:string ]
    ] .

# Gene entities from expression change results
<#GeneFromExpressionMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT DISTINCT gene_symbol
            FROM relationship.has_expression_change_results_by_microbiota
            UNION
            SELECT DISTINCT gene_symbol
            FROM relationship.has_expression_change_results_by_metabolite
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/gene/{gene_symbol}" ;
        rr:class onto:Gene
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:gene_symbol ;
        rr:objectMap [ rr:column "gene_symbol" ; rr:datatype xsd:string ]
    ] .

# ====================================================================
# 关系属性映射 - Relationship Property Mappings
# ====================================================================

# Expression Change Microbiota Relationship Property Mapping
<#ExpressionChangeMicrobiotaRelationshipPropertyMapping>
    rr:logicalTable [ rr:tableName "has_expression_change_results_by_microbiota" ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/microbiota_gene_relationship/{gene_symbol}_{index}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_name ;
        rr:objectMap [ rr:column "relationship" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:gene_symbol ;
        rr:objectMap [ rr:column "gene_symbol" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:result_index ;
        rr:objectMap [ rr:column "index" ; rr:datatype xsd:integer ]
    ] .

# Expression Change Metabolite Relationship Property Mapping
<#ExpressionChangeMetaboliteRelationshipPropertyMapping>
    rr:logicalTable [ rr:tableName "has_expression_change_results_by_metabolite" ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/metabolite_gene_relationship/{gene_symbol}_{index}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:metabolite_name ;
        rr:objectMap [ rr:column "relationship" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:gene_symbol ;
        rr:objectMap [ rr:column "gene_symbol" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:result_index ;
        rr:objectMap [ rr:column "index" ; rr:datatype xsd:integer ]
    ] .

# ====================================================================
# 增强的结果映射 - Enhanced Result Mappings
# ====================================================================

# 确保MicrobiotaGeneChangeResult包含microbiota_name信息
<#MicrobiotaGeneChangeResultWithNameMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT gmgcr.*, hecrbm.relationship as microbiota_name
            FROM newgutmgene.gut_microbiota_gene_change_results gmgcr
            JOIN relationship.has_expression_change_results_by_microbiota hecrbm
            ON gmgcr.index = hecrbm.index
        """
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/ontologies/integrated_gut_microbiota_ontology/microbiota_gene_result/{index}" ;
        rr:class onto:MicrobiotaGeneChangeResult
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_name_in_result ;
        rr:objectMap [ rr:column "microbiota_name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_gene_alteration ;
        rr:objectMap [ rr:column "Alteration" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_gene_index ;
        rr:objectMap [ rr:column "index" ; rr:datatype xsd:integer ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_gene_host_type ;
        rr:objectMap [ rr:column "host_type" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_gene_throughput ;
        rr:objectMap [ rr:column "throughput" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate onto:microbiota_gene_description ;
        rr:objectMap [ rr:column "description" ; rr:datatype xsd:string ]
    ] ;