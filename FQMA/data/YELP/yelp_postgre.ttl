@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix yelp: <http://yelp#> .

# ===================================================================================
# POSTGRESQL DATABASE MAPPINGS FOR YELP ONTOLOGY
# 对应表: business_attributes, checkin, review_text
# ===================================================================================

# ===================================================================================
# Business Attributes Entity Mapping - 商家属性映射
# 对应PostgreSQL表: business_attributes
# 字段: business_id, attributes (jsonb), hours (jsonb), categories (text[])
# ===================================================================================
<#BusinessAttributesMapping>
    rr:logicalTable [ rr:tableName "business_attributes" ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_attributes_{business_id}" ;
        rr:class yelp:BusinessAttributes
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_attributes_json ;
        rr:objectMap [
            rr:column "attributes" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_hours_json ;
        rr:objectMap [
            rr:column "hours" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_categories ;
        rr:objectMap [
            rr:column "categories" ;
            rr:datatype xsd:string
        ]
    ] .

# Business到BusinessAttributes关系映射
<#BusinessToAttributesMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT business_id
            FROM "business_attributes"
        """
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_{business_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_attributes ;
        rr:objectMap [
            rr:template "http://yelp#business_attributes_{business_id}" ;
            rr:termType rr:IRI
        ]
    ] .

# BusinessAttributes完整查询映射（含JSONB展开）
<#BusinessAttributesFullMapping>
    rr:logicalTable [ 
        rr:sqlQuery """
            SELECT business_id, 
                   attributes::text as attributes_text,
                   hours::text as hours_text,
                   array_to_string(categories, ',') as categories_string
            FROM "business_attributes"
        """ 
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_attributes_{business_id}" ;
        rr:class yelp:BusinessAttributes
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_attributes_json ;
        rr:objectMap [
            rr:column "attributes_text" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_hours_json ;
        rr:objectMap [
            rr:column "hours_text" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_categories ;
        rr:objectMap [
            rr:column "categories_string" ;
            rr:datatype xsd:string
        ]
    ] .

# 按类别查询商家属性
<#BusinessAttributesByCategoryMapping>
    rr:logicalTable [ 
        rr:sqlQuery """
            SELECT business_id,
                   array_to_string(categories, ',') as categories_string
            FROM "business_attributes"
            WHERE categories IS NOT NULL
        """ 
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_attributes_{business_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_categories ;
        rr:objectMap [
            rr:column "categories_string" ;
            rr:datatype xsd:string
        ]
    ] .

# ===================================================================================
# Checkin Entity Mapping - 签到记录映射
# 对应PostgreSQL表: checkin
# 字段: business_id, checkin_time
# 主键: (business_id, checkin_time)
# ===================================================================================
<#CheckinMapping>
    rr:logicalTable [ rr:tableName "checkin" ] ;
    rr:subjectMap [
        rr:template "http://yelp#checkin_{business_id}_{checkin_time}" ;
        rr:class yelp:Checkin
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_checkin_time ;
        rr:objectMap [
            rr:column "checkin_time" ;
            rr:datatype xsd:dateTime
        ]
    ] .

# Business到Checkin关系映射
<#BusinessToCheckinMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT business_id, checkin_time
            FROM "checkin"
        """
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_{business_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_checkin ;
        rr:objectMap [
            rr:template "http://yelp#checkin_{business_id}_{checkin_time}" ;
            rr:termType rr:IRI
        ]
    ] .

# Checkin完整查询（包含时间范围筛选）
<#CheckinFullMapping>
    rr:logicalTable [ 
        rr:sqlQuery """
            SELECT business_id, checkin_time
            FROM "checkin"
            ORDER BY checkin_time DESC
        """ 
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#checkin_{business_id}_{checkin_time}" ;
        rr:class yelp:Checkin
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_checkin_time ;
        rr:objectMap [
            rr:column "checkin_time" ;
            rr:datatype xsd:dateTime
        ]
    ] .

# 按商家分组的签到统计
<#CheckinByBusinessMapping>
    rr:logicalTable [ 
        rr:sqlQuery """
            SELECT business_id, 
                   MIN(checkin_time) as first_checkin,
                   MAX(checkin_time) as last_checkin,
                   COUNT(*) as checkin_count
            FROM "checkin"
            GROUP BY business_id
        """ 
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_{business_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_business_id ;
        rr:objectMap [
            rr:column "business_id" ;
            rr:datatype xsd:string
        ]
    ] .

# ===================================================================================
# Review Text Entity Mapping - 评论文本映射
# 对应PostgreSQL表: review_text
# 字段: review_id, user_id, business_id, text, date, text_vector (generated)
# ===================================================================================
<#ReviewTextMapping>
    rr:logicalTable [ rr:tableName "review_text" ] ;
    rr:subjectMap [
        rr:template "http://yelp#review_{review_id}" ;
        rr:class yelp:Review
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_review_id ;
        rr:objectMap [
            rr:column "review_id" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_text ;
        rr:objectMap [
            rr:column "text" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_date ;
        rr:objectMap [
            rr:column "date" ;
            rr:datatype xsd:dateTime
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:written_by ;
        rr:objectMap [
            rr:template "http://yelp#user_{user_id}" ;
            rr:termType rr:IRI
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:reviews_business ;
        rr:objectMap [
            rr:template "http://yelp#business_{business_id}" ;
            rr:termType rr:IRI
        ]
    ] .

# Review到User关系映射
<#ReviewTextToUserMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT review_id, user_id
            FROM "review_text"
            WHERE user_id IS NOT NULL
        """
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#review_{review_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:written_by ;
        rr:objectMap [
            rr:template "http://yelp#user_{user_id}" ;
            rr:termType rr:IRI
        ]
    ] .

# Review到Business关系映射
<#ReviewTextToBusinessMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT review_id, business_id
            FROM "review_text"
            WHERE business_id IS NOT NULL
        """
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#review_{review_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:reviews_business ;
        rr:objectMap [
            rr:template "http://yelp#business_{business_id}" ;
            rr:termType rr:IRI
        ]
    ] .

# Business has_review 反向关系映射
<#BusinessHasReviewTextMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT business_id, review_id
            FROM "review_text"
            WHERE business_id IS NOT NULL
        """
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_{business_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_review ;
        rr:objectMap [
            rr:template "http://yelp#review_{review_id}" ;
            rr:termType rr:IRI
        ]
    ] .

# ReviewText完整查询映射
<#ReviewTextFullMapping>
    rr:logicalTable [ 
        rr:sqlQuery """
            SELECT review_id, user_id, business_id, text, date
            FROM "review_text"
            WHERE text IS NOT NULL
        """ 
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#review_{review_id}" ;
        rr:class yelp:Review
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_review_id ;
        rr:objectMap [
            rr:column "review_id" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_text ;
        rr:objectMap [
            rr:column "text" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_date ;
        rr:objectMap [
            rr:column "date" ;
            rr:datatype xsd:dateTime
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:written_by ;
        rr:objectMap [
            rr:template "http://yelp#user_{user_id}" ;
            rr:termType rr:IRI
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:reviews_business ;
        rr:objectMap [
            rr:template "http://yelp#business_{business_id}" ;
            rr:termType rr:IRI
        ]
    ] .

# 全文搜索映射（利用text_vector）
<#ReviewTextSearchMapping>
    rr:logicalTable [ 
        rr:sqlQuery """
            SELECT review_id, user_id, business_id, text, date
            FROM "review_text"
            WHERE text_vector IS NOT NULL
        """ 
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#review_{review_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_text ;
        rr:objectMap [
            rr:column "text" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_date ;
        rr:objectMap [
            rr:column "date" ;
            rr:datatype xsd:dateTime
        ]
    ] .

# ===================================================================================
# 复合查询映射
# ===================================================================================

# 商家完整信息（属性+签到统计）
<#BusinessCompleteInfoMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT ba.business_id,
                   ba.attributes::text as attributes_text,
                   ba.hours::text as hours_text,
                   array_to_string(ba.categories, ',') as categories_string,
                   COUNT(c.checkin_time) as total_checkins
            FROM "business_attributes" ba
            LEFT JOIN "checkin" c ON ba.business_id = c.business_id
            GROUP BY ba.business_id, ba.attributes, ba.hours, ba.categories
        """
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_attributes_{business_id}" ;
        rr:class yelp:BusinessAttributes
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_attributes_json ;
        rr:objectMap [
            rr:column "attributes_text" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_hours_json ;
        rr:objectMap [
            rr:column "hours_text" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_categories ;
        rr:objectMap [
            rr:column "categories_string" ;
            rr:datatype xsd:string
        ]
    ] .

# 商家的评论文本列表
<#BusinessReviewTextsMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT rt.business_id, rt.review_id, rt.text, rt.date, rt.user_id
            FROM "review_text" rt
            WHERE rt.text IS NOT NULL
            ORDER BY rt.date DESC
        """
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_{business_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_review ;
        rr:objectMap [
            rr:template "http://yelp#review_{review_id}" ;
            rr:termType rr:IRI
        ]
    ] .

# 用户的评论文本（带商家ID）
<#UserReviewTextsMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT rt.user_id, rt.review_id, rt.business_id, rt.text, rt.date
            FROM "review_text" rt
            WHERE rt.user_id IS NOT NULL AND rt.text IS NOT NULL
            ORDER BY rt.date DESC
        """
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#review_{review_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_text ;
        rr:objectMap [
            rr:column "text" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_date ;
        rr:objectMap [
            rr:column "date" ;
            rr:datatype xsd:dateTime
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:written_by ;
        rr:objectMap [
            rr:template "http://yelp#user_{user_id}" ;
            rr:termType rr:IRI
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:reviews_business ;
        rr:objectMap [
            rr:template "http://yelp#business_{business_id}" ;
            rr:termType rr:IRI
        ]
    ] .

# 按日期范围查询评论
<#ReviewTextByDateRangeMapping>
    rr:logicalTable [
        rr:sqlQuery """
            SELECT review_id, user_id, business_id, text, date
            FROM "review_text"
            WHERE date IS NOT NULL
            ORDER BY date DESC
        """
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#review_{review_id}" ;
        rr:class yelp:Review
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_review_id ;
        rr:objectMap [
            rr:column "review_id" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_text ;
        rr:objectMap [
            rr:column "text" ;
            rr:datatype xsd:string
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_date ;
        rr:objectMap [
            rr:column "date" ;
            rr:datatype xsd:dateTime
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:written_by ;
        rr:objectMap [
            rr:template "http://yelp#user_{user_id}" ;
            rr:termType rr:IRI
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:reviews_business ;
        rr:objectMap [
            rr:template "http://yelp#business_{business_id}" ;
            rr:termType rr:IRI
        ]
    ] .
