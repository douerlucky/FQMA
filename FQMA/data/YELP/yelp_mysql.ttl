        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_cool ;
        rr:objectMap [ 
            rr:column "cool" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_elite ;
        rr:objectMap [ 
            rr:column "elite" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_fans ;
        rr:objectMap [ 
            rr:column "fans" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_average_stars ;
        rr:objectMap [ 
            rr:column "average_stars" ; 
            rr:datatype xsd:decimal 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_compliment_hot ;
        rr:objectMap [ 
            rr:column "compliment_hot" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_compliment_more ;
        rr:objectMap [ 
            rr:column "compliment_more" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_compliment_profile ;
        rr:objectMap [ 
            rr:column "compliment_profile" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_compliment_cute ;
        rr:objectMap [ 
            rr:column "compliment_cute" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_compliment_list ;
        rr:objectMap [ 
            rr:column "compliment_list" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_compliment_note ;
