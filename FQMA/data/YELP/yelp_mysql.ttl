@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix yelp: <http://yelp#> .

# ===================================================================================
# MYSQL DATABASE MAPPINGS FOR YELP ONTOLOGY
# 对应表: business, review_stats, user
# ===================================================================================

# ===================================================================================
# Business Entity Mapping - 商家基础映射
# 对应MySQL表: business
# ===================================================================================
<#BusinessMapping>
    rr:logicalTable [ 
        rr:sqlQuery """
            SELECT business_id, name, address, city, state, postal_code,
                   latitude, longitude, stars, review_count, is_open, categories
            FROM business
        """ 
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_{business_id}" ;
        rr:class yelp:Business
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_business_id ;
        rr:objectMap [ 
            rr:column "business_id" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_business_name ;
        rr:objectMap [ 
            rr:column "name" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_address ;
        rr:objectMap [ 
            rr:column "address" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_city ;
        rr:objectMap [ 
            rr:column "city" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_state ;
        rr:objectMap [ 
            rr:column "state" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_postal_code ;
        rr:objectMap [ 
            rr:column "postal_code" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_latitude ;
        rr:objectMap [ 
            rr:column "latitude" ; 
            rr:datatype xsd:decimal 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_longitude ;
        rr:objectMap [ 
            rr:column "longitude" ; 
            rr:datatype xsd:decimal 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_stars ;
        rr:objectMap [ 
            rr:column "stars" ; 
            rr:datatype xsd:decimal 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_review_count ;
        rr:objectMap [ 
            rr:column "review_count" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_is_open ;
        rr:objectMap [ 
            rr:column "is_open" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_categories ;
        rr:objectMap [ 
            rr:column "categories" ; 
            rr:datatype xsd:string 
        ]
    ] .

# Business按城市查询映射
<#BusinessByCityMapping>
    rr:logicalTable [ 
        rr:sqlQuery """
            SELECT business_id, name, city, state, stars
            FROM business
            WHERE city IS NOT NULL
        """ 
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#business_{business_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_business_name ;
        rr:objectMap [ 
            rr:column "name" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_city ;
        rr:objectMap [ 
            rr:column "city" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_state ;
        rr:objectMap [ 
            rr:column "state" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_stars ;
        rr:objectMap [ 
            rr:column "stars" ; 
            rr:datatype xsd:decimal 
        ]
    ] .

# ===================================================================================
# User Entity Mapping - 用户基础映射
# 对应MySQL表: user
# ===================================================================================
<#UserMapping>
    rr:logicalTable [ 
        rr:sqlQuery """
            SELECT user_id, name, review_count, yelping_since, useful, funny, cool,
                   elite, fans, average_stars,
                   compliment_hot, compliment_more, compliment_profile, compliment_cute,
                   compliment_list, compliment_note, compliment_plain, compliment_cool,
                   compliment_funny, compliment_writer, compliment_photos
            FROM user
        """ 
    ] ;
    rr:subjectMap [
        rr:template "http://yelp#user_{user_id}" ;
        rr:class yelp:User
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_user_id ;
        rr:objectMap [ 
            rr:column "user_id" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_user_name ;
        rr:objectMap [ 
            rr:column "name" ; 
            rr:datatype xsd:string 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_review_count ;
        rr:objectMap [ 
            rr:column "review_count" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_yelping_since ;
        rr:objectMap [ 
            rr:column "yelping_since" ; 
            rr:datatype xsd:dateTime 
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate yelp:has_useful ;
        rr:objectMap [ 
            rr:column "useful" ; 
            rr:datatype xsd:integer 
        ]
    ] ;
    rr:predicateObjectMap [
