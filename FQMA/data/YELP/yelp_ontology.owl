<?xml version="1.0"?>
<rdf:RDF xmlns="http://yelp#"
     xml:base="http://yelp"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://yelp"/>


    <!--
    ================================================================
    Classes - 类定义
    ================================================================
    -->

    <!-- 核心类 -->
    <owl:Class rdf:about="http://yelp#User">
        <rdfs:label>User</rdfs:label>
        <rdfs:comment>Yelp platform user</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://yelp#Business">
        <rdfs:label>Business</rdfs:label>
        <rdfs:comment>Business entity on Yelp</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://yelp#Review">
        <rdfs:label>Review</rdfs:label>
        <rdfs:comment>User review for a business</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://yelp#Tip">
        <rdfs:label>Tip</rdfs:label>
        <rdfs:comment>User tip for a business</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://yelp#Checkin">
        <rdfs:label>Checkin</rdfs:label>
        <rdfs:comment>Business checkin record</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://yelp#BusinessAttributes">
        <rdfs:label>Business Attributes</rdfs:label>
        <rdfs:comment>Extended attributes for a business</rdfs:comment>
    </owl:Class>

    <!-- 子类关系 -->
    <owl:Class rdf:about="http://yelp#EliteUser">
        <rdfs:subClassOf rdf:resource="http://yelp#User"/>
        <rdfs:label>Elite User</rdfs:label>
        <rdfs:comment>User with elite status</rdfs:comment>
    </owl:Class>


    <!--
    ================================================================
    Object Properties - 对象属性（关系）
    ================================================================
    -->

    <!-- Neo4j 关系 -->
    <owl:ObjectProperty rdf:about="http://yelp#friends_with">
        <rdfs:label>friends with</rdfs:label>
        <rdfs:comment>Friendship relationship between users</rdfs:comment>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://yelp#User"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://yelp#reviewed">
        <rdfs:label>reviewed</rdfs:label>
        <rdfs:comment>User reviewed a business</rdfs:comment>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://yelp#Business"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://yelp#has_review">
        <rdfs:label>has review</rdfs:label>
        <rdfs:comment>Business has a review</rdfs:comment>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://yelp#Review"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://yelp#written_by">
        <rdfs:label>written by</rdfs:label>
        <rdfs:comment>Review written by user</rdfs:comment>
        <rdfs:domain rdf:resource="http://yelp#Review"/>
        <rdfs:range rdf:resource="http://yelp#User"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://yelp#reviews_business">
        <rdfs:label>reviews business</rdfs:label>
        <rdfs:comment>Review is for a specific business</rdfs:comment>
        <rdfs:domain rdf:resource="http://yelp#Review"/>
        <rdfs:range rdf:resource="http://yelp#Business"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://yelp#tipped">
        <rdfs:label>tipped</rdfs:label>
        <rdfs:comment>User gave a tip to a business</rdfs:comment>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://yelp#Business"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://yelp#has_tip">
        <rdfs:label>has tip</rdfs:label>
        <rdfs:comment>Business has a tip</rdfs:comment>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://yelp#Tip"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://yelp#has_attributes">
        <rdfs:label>has attributes</rdfs:label>
        <rdfs:comment>Business has extended attributes</rdfs:comment>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://yelp#BusinessAttributes"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://yelp#has_checkin">
        <rdfs:label>has checkin</rdfs:label>
        <rdfs:comment>Business has checkin record</rdfs:comment>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://yelp#Checkin"/>
    </owl:ObjectProperty>


    <!--
    ================================================================
    Data Properties - 数据属性
    ================================================================
    -->

    <!-- User 属性 (MySQL) -->
    <owl:DatatypeProperty rdf:about="http://yelp#has_user_id">
        <rdfs:label>has user id</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_user_name">
        <rdfs:label>has user name</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_review_count">
        <rdfs:label>has review count</rdfs:label>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://yelp#User"/>
                    <rdf:Description rdf:about="http://yelp#Business"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_yelping_since">
        <rdfs:label>has yelping since</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_useful">
        <rdfs:label>has useful count</rdfs:label>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://yelp#User"/>
                    <rdf:Description rdf:about="http://yelp#Review"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_funny">
        <rdfs:label>has funny count</rdfs:label>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://yelp#User"/>
                    <rdf:Description rdf:about="http://yelp#Review"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_cool">
        <rdfs:label>has cool count</rdfs:label>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://yelp#User"/>
                    <rdf:Description rdf:about="http://yelp#Review"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_elite">
        <rdfs:label>has elite status</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_fans">
        <rdfs:label>has fans count</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_average_stars">
        <rdfs:label>has average stars</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_hot">
        <rdfs:label>has compliment hot</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_more">
        <rdfs:label>has compliment more</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_profile">
        <rdfs:label>has compliment profile</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_cute">
        <rdfs:label>has compliment cute</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_list">
        <rdfs:label>has compliment list</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_note">
        <rdfs:label>has compliment note</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_plain">
        <rdfs:label>has compliment plain</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_cool">
        <rdfs:label>has compliment cool</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_funny">
        <rdfs:label>has compliment funny</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_writer">
        <rdfs:label>has compliment writer</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_photos">
        <rdfs:label>has compliment photos</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <!-- Business 属性 (MySQL) -->
    <owl:DatatypeProperty rdf:about="http://yelp#has_business_id">
        <rdfs:label>has business id</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_business_name">
        <rdfs:label>has business name</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_address">
        <rdfs:label>has address</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_city">
        <rdfs:label>has city</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_state">
        <rdfs:label>has state</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_postal_code">
        <rdfs:label>has postal code</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_latitude">
        <rdfs:label>has latitude</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_longitude">
        <rdfs:label>has longitude</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_stars">
        <rdfs:label>has stars rating</rdfs:label>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://yelp#Business"/>
                    <rdf:Description rdf:about="http://yelp#Review"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_is_open">
        <rdfs:label>has is open status</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Business"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_categories">
        <rdfs:label>has categories</rdfs:label>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://yelp#Business"/>
                    <rdf:Description rdf:about="http://yelp#BusinessAttributes"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- Review 属性 (MySQL review_stats) -->
    <owl:DatatypeProperty rdf:about="http://yelp#has_review_id">
        <rdfs:label>has review id</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Review"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_date">
        <rdfs:label>has date</rdfs:label>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://yelp#Review"/>
                    <rdf:Description rdf:about="http://yelp#Tip"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>

    <!-- Review Text 属性 (PostgreSQL review_text) -->
    <owl:DatatypeProperty rdf:about="http://yelp#has_text">
        <rdfs:label>has text</rdfs:label>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://yelp#Review"/>
                    <rdf:Description rdf:about="http://yelp#Tip"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- BusinessAttributes 属性 (PostgreSQL business_attributes) -->
    <owl:DatatypeProperty rdf:about="http://yelp#has_attributes_json">
        <rdfs:label>has attributes json</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#BusinessAttributes"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://yelp#has_hours_json">
        <rdfs:label>has hours json</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#BusinessAttributes"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- Checkin 属性 (PostgreSQL checkin) -->
    <owl:DatatypeProperty rdf:about="http://yelp#has_checkin_time">
        <rdfs:label>has checkin time</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Checkin"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>

    <!-- Tip 属性 (Neo4j TIPPED relationship) -->
    <owl:DatatypeProperty rdf:about="http://yelp#has_compliment_count">
        <rdfs:label>has compliment count</rdfs:label>
        <rdfs:domain rdf:resource="http://yelp#Tip"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>


    <!--
    ================================================================
    Annotations - 注解
    ================================================================
    -->

    <rdf:Description rdf:about="http://yelp#User">
        <rdfs:comment>Yelp platform user with profile information</rdfs:comment>
    </rdf:Description>

    <rdf:Description rdf:about="http://yelp#Business">
        <rdfs:comment>Business entity registered on Yelp platform</rdfs:comment>
    </rdf:Description>

    <rdf:Description rdf:about="http://yelp#Review">
        <rdfs:comment>User review containing rating and feedback for a business</rdfs:comment>
    </rdf:Description>

</rdf:RDF>
