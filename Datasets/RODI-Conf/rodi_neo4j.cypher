:begin
CREATE RANGE INDEX FOR (n:Conference) ON (n.name);
CREATE RANGE INDEX FOR (n:Paper) ON (n.title);
CREATE RANGE INDEX FOR (n:Person) ON (n.last_name);
CREATE CONSTRAINT committee_id FOR (node:Committee) REQUIRE (node.ID) IS UNIQUE;
CREATE CONSTRAINT conference_id FOR (node:Conference) REQUIRE (node.ID) IS UNIQUE;
CREATE CONSTRAINT paper_id FOR (node:Paper) REQUIRE (node.ID) IS UNIQUE;
CREATE CONSTRAINT person_id FOR (node:Person) REQUIRE (node.ID) IS UNIQUE;
:commit
CALL db.awaitIndexes(300);
